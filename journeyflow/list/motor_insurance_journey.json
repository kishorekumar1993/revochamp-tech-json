      ],
      "validations": [],
      "conditions": [],
      "apiCalls": [],
      "actions": []
    },
    {
      "id": "success",
      "title": "Success",
      "description": "Your policy generated successfully!",
      "fields": [
        {
          "id": "successDiv",
          "label": "Congratulations! Policy PDF has been sent to your email.",
          "type": "divider",
          "required": false,
          "visible": true,
          "readOnly": false,
          "useStaticOptions": false,
          "disable": false,
          "hidden": false,
          "api": false,
          "obscureText": false,
          "autocorrect": true,
          "enableSuggestions": true
        }
      ],
      "validations": [],
      "conditions": [],
      "apiCalls": [],
      "actions": []
    }
  ]
}