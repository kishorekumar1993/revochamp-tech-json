  "content": [
    {
      "type": "heading",
      "value": "What are Conditional Types?"
    },
    {
      "type": "text",
      "value": "Conditional types allow you to define types based on conditions using the extends keyword, similar to if-else logic."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "type IsString<T> = T extends string ? true : false;"
    },
    {
      "type": "heading",
      "value": "Example Usage"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "type A = IsString<string>; // true\ntype B = IsString<number>; // false"
    },
    {
      "type": "heading",
      "value": "Using infer Keyword"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "type ReturnType<T> = T extends (...args: any[]) => infer R ? R : never;"
    },
    {
      "type": "heading",
      "value": "Conditional with Union"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "type ToArray<T> = T extends any ? T[] : never;"
    },
    {
      "type": "heading",
      "value": "Nested Conditions"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "type TypeName<T> =\n  T extends string ? 'string' :\n  T extends number ? 'number' :\n  'other';"
    },
