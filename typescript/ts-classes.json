      "type": "heading",
      "value": "What is a Class?"
    },
    {
      "type": "text",
      "value": "A class in TypeScript is a blueprint for creating objects, supporting object-oriented programming features like encapsulation and inheritance."
    },
    {
      "type": "heading",
      "value": "Basic Class Example"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "class User {\n  name: string;\n\n  constructor(name: string) {\n    this.name = name;\n  }\n}\n\nconst u = new User('John');"
    },
    {
      "type": "heading",
      "value": "Access Modifiers"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "class Person {\n  public name: string;\n  private age: number;\n  protected id: number;\n}"
    },
    {
      "type": "heading",
      "value": "Readonly Properties"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "class User {\n  readonly id: number;\n\n  constructor(id: number) {\n    this.id = id;\n  }\n}"
    },
    {
      "type": "heading",
      "value": "Methods"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "class User {\n  greet(): string {\n    return 'Hello';\n  }\n}"
    },
    {
      "type": "heading",
      "value": "Inheritance"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "class Animal {\n  move() {\n    console.log('Moving');\n  }\n}\n\nclass Dog extends Animal {\n  bark() {\n    console.log('Bark');\n  }\n}"
    },
    {
      "type": "heading",
      "value": "Constructor Short Syntax"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "class User {\n  constructor(public name: string) {}\n}"
    },
