  "content": [
    {
      "type": "heading",
      "value": "What are Modules?"
    },
    {
      "type": "text",
      "value": "Modules allow you to split code into separate files and reuse functionality using import and export statements."
    },
    {
      "type": "heading",
      "value": "Export Example"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "export const name: string = 'TypeScript';\n\nexport function greet() {\n  console.log('Hello');\n}"
    },
    {
      "type": "heading",
      "value": "Import Example"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "import { name, greet } from './module';\n\ngreet();"
    },
    {
      "type": "heading",
      "value": "Default Export"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "export default function greet() {\n  console.log('Hello');\n}"
    },
    {
      "type": "heading",
      "value": "Import Default"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "import greet from './module';"
    },
    {
      "type": "heading",
      "value": "Alias Import"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "import { greet as sayHello } from './module';"
    },
    {
