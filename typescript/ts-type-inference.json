      "type": "heading",
      "value": "What is Type Inference?"
    },
    {
      "type": "text",
      "value": "Type inference is a feature in TypeScript where the compiler automatically determines the type of a variable based on its value."
    },
    {
      "type": "heading",
      "value": "Basic Example"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "let name = 'John'; // inferred as string\nlet age = 25; // inferred as number"
    },
    {
      "type": "heading",
      "value": "Function Inference"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "function add(a: number, b: number) {\n  return a + b; // inferred return type: number\n}"
    },
    {
      "type": "heading",
      "value": "Array Inference"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "let numbers = [1, 2, 3]; // number[]\nlet mixed = [1, 'A']; // (number | string)[]"
    },
    {
      "type": "heading",
      "value": "Object Inference"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "let user = {\n  name: 'John',\n  age: 30\n};"
    },
