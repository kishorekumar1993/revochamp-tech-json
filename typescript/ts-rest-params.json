    },
    {
      "type": "text",
      "value": "Rest parameters allow a function to accept an indefinite number of arguments as an array."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "function sum(...numbers: number[]): number {\n  return numbers.reduce((a, b) => a + b, 0);\n}"
    },
