    },
    {
      "type": "text",
      "value": "Declaration files (.d.ts) provide type information about JavaScript code without including actual implementation."
    },
    {
      "type": "heading",
      "value": "Why Use Declaration Files?"
    },
    {
      "type": "list",
      "value": [
        "**Provide type safety for JS libraries**",
        "**Enable IntelliSense support**",
        "**Improve developer experience**",
        "**Avoid runtime errors**"
      ]
    },
    {
      "type": "heading",
      "value": "Basic Example"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "declare function greet(name: string): void;"
    },
    {
      "type": "heading",
      "value": "Module Declaration"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "declare module 'my-lib' {\n  export function add(a: number, b: number): number;\n}"
    },
