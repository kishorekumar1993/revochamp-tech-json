      "type": "heading",
      "value": "What are Utility Types?"
    },
    {
      "type": "text",
      "value": "Utility types are built-in TypeScript helpers that transform existing types into new types."
    },
    {
      "type": "heading",
      "value": "Partial"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "interface User {\n  name: string;\n  age: number;\n}\n\nconst user: Partial<User> = { name: 'John' };"
    },
    {
      "type": "heading",
      "value": "Required"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "const user: Required<User> = {\n  name: 'John',\n  age: 30\n};"
    },
    {
      "type": "heading",
      "value": "Readonly"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "const user: Readonly<User> = {\n  name: 'John',\n  age: 30\n};"
    },
    {
      "type": "heading",
      "value": "Pick"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "type UserName = Pick<User, 'name'>;"
    },
    {
      "type": "heading",
      "value": "Omit"
    },
    {
      "type": "code",
      "language": "typescript",
