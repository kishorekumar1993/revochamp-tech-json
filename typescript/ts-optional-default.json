  "faq": [
    {
      "question": "What is optional parameter?",
      "answer": "A parameter that may not be provided."
    },
    {
      "question": "What is default parameter?",
      "answer": "A parameter with a default value."
    },
    {
      "question": "Which is better?",
      "answer": "Default parameters are more predictable."
