  "content": [
    {
      "type": "heading",
      "value": "What are Optional Parameters?"
    },
    {
      "type": "text",
      "value": "Optional parameters allow you to define function parameters that may or may not be provided when the function is called."
    },
    {
      "type": "heading",
      "value": "Optional Parameter Syntax"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "function greet(name?: string) {\n  return name || 'Guest';\n}"
    },
    {
      "type": "heading",
      "value": "Default Parameters"
    },
    {
      "type": "text",
      "value": "Default parameters assign a default value when no argument is passed."
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "function greet(name: string = 'Guest') {\n  return name;\n}"
    },
    {
      "type": "heading",
      "value": "Optional vs Default"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Feature", "Optional", "Default"],
        "rows": [
          ["Value Required", "No", "No"],
          ["Default Value", "No", "Yes"],
          ["Usage", "Flexible input", "Predefined fallback"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Combining Both"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "function greet(name?: string, age: number = 18) {\n  return `${name || 'Guest'} - ${age}`;\n}"
    },
    {
      "type": "heading",
      "value": "Parameter Order Rules"
    },
    {
      "type": "text",
      "value": "Optional parameters must come after required parameters, while default parameters can be placed flexibly but should follow best practices."
    },
    {
      "type": "heading",
      "value": "Best Practices"
    },
    {
      "type": "list",
