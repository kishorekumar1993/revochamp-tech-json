  "faq": [
    {
      "question": "What is public?",
      "answer": "Accessible everywhere."
    },
    {
      "question": "What is private?",
      "answer": "Accessible only inside class."
    },
    {
      "question": "What is protected?",
      "answer": "Accessible in class and subclasses."
