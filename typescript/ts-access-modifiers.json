  "content": [
    {
      "type": "heading",
      "value": "What are Access Modifiers?"
    },
    {
      "type": "text",
      "value": "Access modifiers control the visibility and accessibility of class properties and methods in TypeScript."
    },
    {
      "type": "heading",
      "value": "Types of Modifiers"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Modifier", "Access Level"],
        "rows": [
          ["public", "Accessible everywhere"],
          ["private", "Accessible only within class"],
          ["protected", "Accessible within class and subclasses"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Public Example"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "class User {\n  public name: string = 'John';\n}"
    },
    {
      "type": "heading",
      "value": "Private Example"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "class User {\n  private age: number = 30;\n}"
    },
    {
      "type": "heading",
      "value": "Protected Example"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "class Person {\n  protected id: number = 1;\n}\n\nclass Employee extends Person {\n  getId() {\n    return this.id;\n  }\n}"
    },
    {
      "type": "heading",
      "value": "Constructor Shortcut"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "class User {\n  constructor(public name: string, private age: number) {}\n}"
    },
    {
      "type": "heading",
      "value": "Encapsulation"
    },
    {
      "type": "text",
      "value": "Access modifiers help achieve encapsulation by hiding internal implementation details and exposing only necessary data."
    },
    {
      "type": "heading",
      "value": "Best Practices"
    },
    {
      "type": "list",
      "value": [
        "**Use private for sensitive data**",
