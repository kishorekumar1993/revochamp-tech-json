    {
      "type": "heading",
      "value": "Optional Parameters"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "function greet(name?: string) {\n  return name || 'Guest';\n}"
    },
    {
      "type": "heading",
      "value": "Default Parameters"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "function greet(name: string = 'Guest') {\n  return name;\n}"
    },
    {
      "type": "heading",
