      "type": "heading",
      "value": "What are Events?"
    },
    {
      "type": "text",
      "value": "Events are actions or occurrences that happen in the browser, such as clicks, inputs, or keyboard actions."
    },
    {
      "type": "heading",
      "value": "Basic Event Handling"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "const btn = document.querySelector('button') as HTMLButtonElement;\n\nbtn.addEventListener('click', () => {\n  console.log('Clicked');\n});"
    },
    {
      "type": "heading",
      "value": "Typed Event"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "btn.addEventListener('click', (e: MouseEvent) => {\n  console.log(e.clientX);\n});"
    },
    {
      "type": "heading",
      "value": "Input Event"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "const input = document.querySelector('input') as HTMLInputElement;\n\ninput.addEventListener('input', (e: Event) => {\n  console.log(input.value);\n});"
    },
    {
      "type": "heading",
      "value": "Keyboard Event"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "document.addEventListener('keydown', (e: KeyboardEvent) => {\n  console.log(e.key);\n});"
    },
    {
      "type": "heading",
      "value": "Event Types"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Event", "Type"],
