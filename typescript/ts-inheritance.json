  "content": [
    {
      "type": "heading",
      "value": "What is Inheritance?"
    },
    {
      "type": "text",
      "value": "Inheritance allows a class to reuse properties and methods from another class using the extends keyword."
    },
    {
      "type": "heading",
      "value": "Basic Example"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "class Animal {\n  move() {\n    console.log('Moving');\n  }\n}\n\nclass Dog extends Animal {\n  bark() {\n    console.log('Bark');\n  }\n}"
    },
    {
      "type": "heading",
      "value": "Using super()"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "class Animal {\n  constructor(public name: string) {}\n}\n\nclass Dog extends Animal {\n  constructor(name: string) {\n    super(name);\n  }\n}"
    },
    {
      "type": "heading",
      "value": "Method Overriding"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "class Animal {\n  speak() {\n    console.log('Animal sound');\n  }\n}\n\nclass Dog extends Animal {\n  speak() {\n    console.log('Bark');\n  }\n}"
    },
    {
      "type": "heading",
      "value": "Access Modifiers in Inheritance"
    },
    {
      "type": "text",
      "value": "Protected members can be accessed in subclasses, while private members cannot."
    },
