    {
      "type": "heading",
      "value": "What are Generics?"
    },
    {
      "type": "text",
      "value": "Generics allow you to create reusable components that work with multiple data types while maintaining type safety."
    },
    {
      "type": "heading",
      "value": "Basic Generic Function"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "function identity<T>(value: T): T {\n  return value;\n}"
    },
    {
      "type": "heading",
      "value": "Using Generics"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "identity<string>('Hello');\nidentity<number>(10);"
    },
    {
      "type": "heading",
      "value": "Generic Interface"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "interface Box<T> {\n  value: T;\n}"
    },
    {
      "type": "heading",
      "value": "Generic Class"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "class DataStore<T> {\n  data: T[] = [];\n\n  add(item: T) {\n    this.data.push(item);\n  }\n}"
    },
    {
      "type": "heading",
      "value": "Generic Constraints"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "function printLength<T extends { length: number }>(item: T) {\n  console.log(item.length);\n}"
    },
    {
      "type": "heading",
      "value": "Multiple Generics"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "function pair<K, V>(key: K, value: V) {\n  return { key, value };\n}"
    },
