    },
    {
      "type": "text",
      "value": "Types in TypeScript define the kind of data a variable can hold, ensuring type safety and better code quality."
    },
    {
      "type": "heading",
      "value": "Primitive Types"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "let name: string = 'John';\nlet age: number = 25;\nlet isActive: boolean = true;"
    },
    {
      "type": "heading",
      "value": "Array Types"
    },
    {
      "type": "code",
      "language": "typescript",
      "value": "let nums: number[] = [1, 2, 3];\nlet names: Array<string> = ['A', 'B'];"
    },
    {
      "type": "heading",
      "value": "Tuple"
    },
    {
      "type": "code",
      "language": "typescript",
