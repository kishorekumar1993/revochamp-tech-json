    {
      "type": "heading",
      "value": "What is the Dialog Element?"
    },
    {
      "type": "text",
      "value": "The <dialog> element is used to create native modals, popups, and interactive dialogs in HTML without external libraries."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<dialog open>\n  <p>This is a dialog box</p>\n</dialog>"
    },
    {
      "type": "heading",
      "value": "Open and Close Dialog"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<dialog id=\"myDialog\">\n  <p>Hello Dialog</p>\n  <button onclick=\"document.getElementById('myDialog').close()\">Close</button>\n</dialog>\n\n<button onclick=\"document.getElementById('myDialog').showModal()\">Open Dialog</button>"
    },
    {
      "type": "heading",
      "value": "Dialog Methods"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Method", "Description"],
        "rows": [
          ["show()", "Opens dialog (non-modal)"],
          ["showModal()", "Opens dialog as modal"],
          ["close()", "Closes dialog"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Form Inside Dialog"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<dialog id=\"formDialog\">\n  <form method=\"dialog\">\n    <p>Are you sure?</p>\n    <button value=\"yes\">Yes</button>\n    <button value=\"no\">No</button>\n  </form>\n</dialog>\n\n<button onclick=\"formDialog.showModal()\">Open</button>"
    },
    {
      "type": "heading",
      "value": "Styling Dialog"
    },
    {
      "type": "code",
      "language": "css",
      "value": "dialog {\n  border: none;\n  border-radius: 10px;\n  padding: 20px;\n}\n\ndialog::backdrop {\n  background: rgba(0,0,0,0.5);\n}"
    },
