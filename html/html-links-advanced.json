    {
      "type": "heading",
      "value": "What are Advanced HTML Links?"
    },
    {
      "type": "text",
      "value": "Advanced HTML links extend the basic <a> tag functionality to include navigation behaviors, downloads, emails, and more."
    },
    {
      "type": "heading",
      "value": "Open Links in New Tab"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<a href=\"https://example.com\" target=\"_blank\">Open in new tab</a>"
    },
    {
      "type": "heading",
      "value": "Download Attribute"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<a href=\"file.pdf\" download>Download PDF</a>"
    },
    {
      "type": "heading",
      "value": "Email Links (mailto)"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<a href=\"mailto:example@mail.com\">Send Email</a>"
    },
    {
      "type": "heading",
      "value": "Phone Links (tel)"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<a href=\"tel:+1234567890\">Call Now</a>"
    },
    {
      "type": "heading",
      "value": "Anchor Links (Jump to Section)"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<a href=\"#section1\">Go to Section</a>\n\n<h2 id=\"section1\">Section 1</h2>"
    },
    {
      "type": "heading",
      "value": "Linking to Specific Page Section"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<a href=\"page.html#section\">Go to section in another page</a>"
    },
    {
      "type": "heading",
      "value": "Image as Link"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<a href=\"https://example.com\">\n  <img src=\"image.jpg\" alt=\"Example\">\n</a>"
    },
    {
      "type": "heading",
      "value": "Button-like Link"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<a href=\"#\" style=\"display:inline-block; padding:10px; background:#333; color:#fff; text-decoration:none;\">Click Me</a>"
    },
    {
      "type": "heading",
      "value": "Rel Attribute"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<a href=\"https://example.com\" target=\"_blank\" rel=\"noopener noreferrer\">Secure Link</a>"
    },
    {
