      "value": "What are Google Fonts?"
    },
    {
      "type": "text",
      "value": "Google Fonts is a free library of web fonts that you can use to enhance typography in your website."
    },
    {
      "type": "heading",
      "value": "Using Link Tag (Recommended)"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<link href=\"https://fonts.googleapis.com/css2?family=Roboto&display=swap\" rel=\"stylesheet\">"
    },
    {
      "type": "code",
      "language": "css",
      "value": "body {\n  font-family: 'Roboto', sans-serif;\n}"
    },
    {
      "type": "heading",
      "value": "Using @import"
    },
    {
      "type": "code",
      "language": "css",
      "value": "@import url('https://fonts.googleapis.com/css2?family=Open+Sans&display=swap');\n\nbody {\n  font-family: 'Open Sans', sans-serif;\n}"
    },
    {
      "type": "heading",
      "value": "Multiple Fonts"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<link href=\"https://fonts.googleapis.com/css2?family=Roboto&family=Poppins&display=swap\" rel=\"stylesheet\">"
    },
    {
      "type": "heading",
      "value": "Font Weights"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<link href=\"https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;700&display=swap\" rel=\"stylesheet\">"
    },
    {
      "type": "code",
      "language": "css",
      "value": "h1 {\n  font-weight: 700;\n}"
    },
    {
      "type": "heading",
      "value": "Performance Optimization"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>"
    },
    {
      "type": "heading",
      "value": "Fallback Fonts"
    },
    {
      "type": "code",
      "language": "css",
      "value": "body {\n  font-family: 'Roboto', Arial, sans-serif;\n}"
    },
