    {
      "type": "heading",
      "value": "What is HTML Audio?"
    },
    {
      "type": "text",
      "value": "HTML audio allows you to embed sound files like music or voice into web pages using the <audio> tag."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<audio controls>\n  <source src=\"audio.mp3\" type=\"audio/mpeg\">\n  Your browser does not support the audio element.\n</audio>"
    },
    {
      "type": "heading",
      "value": "Audio Attributes"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Attribute", "Description"],
        "rows": [
          ["controls", "Shows play/pause controls"],
          ["autoplay", "Starts audio automatically"],
          ["loop", "Repeats audio"],
          ["muted", "Starts audio muted"],
          ["preload", "Hints how audio should be loaded"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Supported Audio Formats"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Format", "Type"],
        "rows": [
          ["MP3", "audio/mpeg"],
          ["WAV", "audio/wav"],
          ["OGG", "audio/ogg"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Multiple Source Example"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<audio controls>\n  <source src=\"audio.mp3\" type=\"audio/mpeg\">\n  <source src=\"audio.ogg\" type=\"audio/ogg\">\n</audio>"
    },
    {
      "type": "heading",
      "value": "Autoplay and Loop Example"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<audio controls autoplay loop>\n  <source src=\"audio.mp3\" type=\"audio/mpeg\">\n</audio>"
    },
    {
      "type": "heading",
      "value": "Fallback Text"
    },
    {
      "type": "text",
      "value": "Fallback text is displayed if the browser does not support the audio element."
    },
    {
      "type": "code",
      "language": "html",
      "value": "<audio controls>\n  <source src=\"audio.mp3\" type=\"audio/mpeg\">\n  Your browser does not support HTML audio.\n</audio>"
    },
