  "faq": [
    {
      "question": "What is the difference between progress and meter?",
      "answer": "Progress shows task completion, while meter shows a value within a range."
    },
    {
      "question": "Can I style progress bars?",
      "answer": "Yes, using CSS (browser support varies)."
    },
    {
      "question": "Is meter used for loading?",
