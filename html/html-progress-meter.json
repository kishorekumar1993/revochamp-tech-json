          ["Example", "Loading bar", "Battery level"],
          ["Attributes", "value, max", "min, max, low, high"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Styling with CSS"
    },
    {
      "type": "code",
      "language": "css",
