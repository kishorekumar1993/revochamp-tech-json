  "content": [
    {
      "type": "heading",
      "value": "What is CSS Position?"
    },
    {
      "type": "text",
      "value": "The position property controls how an element is positioned in the document using top, right, bottom, and left values."
    },
    {
      "type": "heading",
      "value": "Position Types"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Value", "Description"],
        "rows": [
          ["static", "Default position"],
          ["relative", "Relative to itself"],
          ["absolute", "Relative to nearest positioned parent"],
          ["fixed", "Fixed to viewport"],
          ["sticky", "Switches between relative and fixed"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Static Position"
    },
    {
      "type": "code",
      "language": "css",
      "value": "div {\n  position: static;\n}"
    },
    {
      "type": "heading",
      "value": "Relative Position"
    },
    {
      "type": "text",
      "value": "Moves relative to its original position."
    },
    {
      "type": "code",
      "language": "css",
      "value": "div {\n  position: relative;\n  top: 10px;\n  left: 20px;\n}"
    },
    {
      "type": "heading",
      "value": "Absolute Position"
    },
    {
      "type": "text",
      "value": "Positions element relative to nearest positioned ancestor."
    },
    {
      "type": "code",
      "language": "css",
      "value": "div {\n  position: absolute;\n  top: 0;\n  right: 0;\n}"
    },
    {
      "type": "heading",
      "value": "Fixed Position"
    },
    {
      "type": "text",
      "value": "Stays fixed relative to viewport."
    },
    {
      "type": "code",
      "language": "css",
      "value": "div {\n  position: fixed;\n  bottom: 10px;\n  right: 10px;\n}"
    },
    {
      "type": "heading",
      "value": "Sticky Position"
    },
    {
      "type": "text",
      "value": "Acts like relative until a scroll threshold is reached."
    },
    {
      "type": "code",
      "language": "css",
      "value": "div {\n  position: sticky;\n  top: 0;\n}"
    },
    {
      "type": "heading",
      "value": "Z-Index"
    },
    {
      "type": "text",
      "value": "Controls stacking order of positioned elements."
    },
    {
      "type": "code",
      "language": "css",
      "value": "div {\n  position: absolute;\n  z-index: 10;\n}"
    },
    {
      "type": "heading",
      "value": "Positioning Example"
    },
    {
      "type": "code",
      "language": "css",
      "value": ".parent {\n  position: relative;\n}\n\n.child {\n  position: absolute;\n  top: 0;\n  left: 0;\n}"
    },
    {
      "type": "heading",
      "value": "Best Practices"
    },
