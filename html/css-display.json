    {
      "type": "code",
      "language": "css",
      "value": "div {\n  display: block;\n}"
    },
    {
      "type": "heading",
      "value": "Inline Elements"
    },
    {
      "type": "text",
      "value": "Inline elements take only necessary width and stay in the same line."
    },
    {
      "type": "code",
      "language": "css",
      "value": "span {\n  display: inline;\n}"
    },
    {
      "type": "heading",
      "value": "Inline-Block"
    },
    {
      "type": "text",
      "value": "Allows width and height while staying inline."
