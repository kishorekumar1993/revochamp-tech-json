  "content": [
    {
      "type": "heading",
      "value": "What are Data Attributes?"
    },
    {
      "type": "text",
      "value": "HTML data attributes allow you to store custom data directly on HTML elements using the data-* format."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<div data-user=\"john\" data-id=\"123\"></div>"
    },
    {
      "type": "heading",
      "value": "Accessing Data in JavaScript"
    },
    {
      "type": "code",
      "language": "javascript",
      "value": "const el = document.querySelector('div');\nconsole.log(el.dataset.user); // john\nconsole.log(el.dataset.id);   // 123"
    },
    {
      "type": "heading",
      "value": "Accessing with getAttribute"
    },
    {
      "type": "code",
      "language": "javascript",
      "value": "el.getAttribute('data-user');"
    },
    {
      "type": "heading",
      "value": "Setting Data Attributes"
    },
    {
      "type": "code",
      "language": "javascript",
      "value": "el.dataset.user = 'alice';\nel.setAttribute('data-role', 'admin');"
    },
    {
      "type": "heading",
      "value": "Using Data Attributes in CSS"
    },
    {
      "type": "code",
      "language": "css",
      "value": "[data-role=\"admin\"] {\n  background: #eee;\n}"
    },
    {
      "type": "heading",
      "value": "Example Use Case"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<button data-product-id=\"101\">Add to Cart</button>"
    },
