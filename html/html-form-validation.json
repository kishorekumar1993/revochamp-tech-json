  "content": [
    {
      "type": "heading",
      "value": "What is HTML Form Validation?"
    },
    {
      "type": "text",
      "value": "HTML form validation ensures that users enter correct and complete data before submitting a form. It helps improve data quality and user experience."
    },
    {
      "type": "heading",
      "value": "Basic Example"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<form>\n  <input type=\"text\" required placeholder=\"Name\">\n  <input type=\"email\" required placeholder=\"Email\">\n  <button type=\"submit\">Submit</button>\n</form>"
    },
    {
      "type": "heading",
      "value": "Common Validation Attributes"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Attribute", "Description", "Example"],
        "rows": [
          ["required", "Field must be filled", "<input required>"],
          ["minlength", "Minimum characters", "<input minlength=\"3\">"],
          ["maxlength", "Maximum characters", "<input maxlength=\"10\">"],
          ["pattern", "Custom regex validation", "<input pattern=\"[0-9]{10}\">"],
          ["min", "Minimum value", "<input type=\"number\" min=\"1\">"],
          ["max", "Maximum value", "<input type=\"number\" max=\"100\">"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Email Validation"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<input type=\"email\" required placeholder=\"Enter email\">"
    },
    {
      "type": "heading",
      "value": "Pattern Validation (Regex)"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<input type=\"text\" pattern=\"[A-Za-z]{3,}\" title=\"Only letters, min 3 characters\">"
    },
    {
      "type": "heading",
      "value": "Number Validation"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<input type=\"number\" min=\"1\" max=\"10\">"
    },
    {
      "type": "heading",
      "value": "Custom Validation Message"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<input type=\"text\" required oninvalid=\"this.setCustomValidity('Please enter your name')\" oninput=\"this.setCustomValidity('')\">"
    },
    {
      "type": "heading",
      "value": "Disable Validation"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<form novalidate>\n  <input type=\"text\">\n</form>"
    },
    {
      "type": "heading",
      "value": "Best Practices"
    },
    {
      "type": "list",
      "value": [
        "**Use built-in validation attributes first**",
        "**Provide clear error messages**",
        "**Use proper input types (email, number, etc.)**",
        "**Validate both client-side and server-side**",
        "**Keep forms simple and user-friendly**"
      ]
    },
    {
      "type": "heading",
      "value": "Common Mistakes"
    },
    {
      "type": "list",
      "value": [
        "**Relying only on client-side validation**",
        "**Not providing helpful error messages**",
        "**Using wrong input types**",
        "**Overcomplicated validation rules**"
      ]
    },
    {
      "type": "heading",
      "value": "Conclusion"
    },
    {
      "type": "text",
      "value": "HTML form validation improves user input accuracy and usability. Using built-in validation features reduces the need for complex JavaScript."
    }
  ],
  "faq": [
    {
      "question": "What is required attribute?",
      "answer": "It ensures the field must be filled before submission."
    },
    {
      "question": "What is pattern attribute?",
      "answer": "It allows validation using regular expressions."
    },
    {
      "question": "Is HTML validation enough?",
      "answer": "No, server-side validation is also required for security."
    }
