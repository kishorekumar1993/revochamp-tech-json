    },
    {
      "type": "text",
      "value": "File paths specify the location of files such as images, CSS, JavaScript, or other pages in HTML."
    },
    {
      "type": "heading",
      "value": "Types of File Paths"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Type", "Description", "Example"],
        "rows": [
          ["Absolute Path", "Full URL to a file", "https://example.com/image.jpg"],
          ["Relative Path", "Path relative to current file", "images/photo.jpg"],
          ["Root Relative", "Path from root directory", "/images/photo.jpg"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Absolute Path Example"
    },
    {
      "type": "code",
      "language": "html",
