  "content": [
    {
      "type": "heading",
      "value": "What is HTML Select?"
    },
    {
      "type": "text",
      "value": "The <select> element is used to create dropdown lists in forms. It allows users to choose one or multiple options from a list."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<select name=\"country\">\n  <option value=\"india\">India</option>\n  <option value=\"usa\">USA</option>\n  <option value=\"uk\">UK</option>\n</select>"
    },
    {
      "type": "heading",
      "value": "Select Attributes"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Attribute", "Description"],
        "rows": [
          ["name", "Name of the field"],
          ["required", "Makes selection mandatory"],
          ["multiple", "Allows multiple selections"],
          ["size", "Number of visible options"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Option Attributes"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Attribute", "Description"],
        "rows": [
          ["value", "Submitted value"],
          ["selected", "Default selected option"],
          ["disabled", "Disables option"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Default Selected Option"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<select>\n  <option>Choose</option>\n  <option selected>India</option>\n  <option>USA</option>\n</select>"
    },
    {
      "type": "heading",
      "value": "Multiple Selection"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<select multiple>\n  <option>HTML</option>\n  <option>CSS</option>\n  <option>JavaScript</option>\n</select>"
    },
    {
      "type": "heading",
      "value": "Grouped Options (optgroup)"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<select>\n  <optgroup label=\"Frontend\">\n    <option>HTML</option>\n    <option>CSS</option>\n  </optgroup>\n  <optgroup label=\"Backend\">\n    <option>Node.js</option>\n    <option>Python</option>\n  </optgroup>\n</select>"
    },
    {
      "type": "heading",
      "value": "Complete Example"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<form>\n  <label>Select Country:</label>\n  <select required>\n    <option value=\"\">Choose Country</option>\n    <option value=\"india\">India</option>\n    <option value=\"usa\">USA</option>\n  </select>\n  <button type=\"submit\">Submit</button>\n</form>"
    },
