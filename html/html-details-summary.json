    {
      "type": "heading",
      "value": "What are Details & Summary?"
    },
    {
      "type": "text",
      "value": "The <details> and <summary> elements are used to create expandable and collapsible content sections without JavaScript."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<details>\n  <summary>Click to expand</summary>\n  <p>This is hidden content.</p>\n</details>"
    },
    {
      "type": "heading",
      "value": "Open by Default"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<details open>\n  <summary>Visible Section</summary>\n  <p>This content is open by default.</p>\n</details>"
    },
    {
      "type": "heading",
      "value": "Multiple Sections (Accordion Style)"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<details>\n  <summary>Section 1</summary>\n  <p>Content 1</p>\n</details>\n\n<details>\n  <summary>Section 2</summary>\n  <p>Content 2</p>\n</details>"
    },
    {
      "type": "heading",
      "value": "Styling with CSS"
    },
    {
      "type": "code",
      "language": "css",
      "value": "details {\n  border: 1px solid #ccc;\n  padding: 10px;\n  border-radius: 5px;\n}\n\nsummary {\n  cursor: pointer;\n  font-weight: bold;\n}"
    },
    {
      "type": "heading",
      "value": "Custom Marker (Arrow)"
    },
    {
      "type": "code",
