    {
      "type": "heading",
      "value": "What are Meta Tags?"
    },
    {
      "type": "text",
      "value": "Meta tags provide metadata about a webpage. They are placed inside the <head> section and are not visible on the page but help browsers and search engines understand content."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<meta name=\"description\" content=\"This is a sample page\">"
    },
    {
      "type": "heading",
      "value": "Common Meta Tags"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Tag", "Purpose"],
        "rows": [
          ["<meta charset=\"UTF-8\">", "Defines character encoding"],
          ["<meta name=\"viewport\">", "Controls responsive layout"],
          ["<meta name=\"description\">", "Page description for SEO"],
          ["<meta name=\"keywords\">", "Keywords for search engines"],
          ["<meta name=\"author\">", "Author of the page"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Viewport Meta Tag"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">"
    },
    {
      "type": "heading",
      "value": "SEO Meta Tags"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<meta name=\"description\" content=\"Learn HTML basics\">\n<meta name=\"keywords\" content=\"HTML, CSS, JavaScript\">\n<meta name=\"author\" content=\"John Doe\">"
    },
    {
      "type": "heading",
      "value": "Open Graph (Social Media)"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<meta property=\"og:title\" content=\"My Website\">\n<meta property=\"og:description\" content=\"Learn web development\">\n<meta property=\"og:image\" content=\"image.jpg\">"
    },
    {
      "type": "heading",
      "value": "Robots Meta Tag"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<meta name=\"robots\" content=\"index, follow\">"
    },
