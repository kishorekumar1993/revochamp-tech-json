  "content": [
    {
      "type": "heading",
      "value": "What is HTML Video?"
    },
    {
      "type": "text",
      "value": "HTML video allows you to embed video content directly into web pages using the <video> tag without relying on external plugins."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<video controls width=\"400\">\n  <source src=\"video.mp4\" type=\"video/mp4\">\n  Your browser does not support the video tag.\n</video>"
    },
    {
      "type": "heading",
      "value": "Video Attributes"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Attribute", "Description"],
        "rows": [
          ["controls", "Displays play/pause controls"],
          ["autoplay", "Starts video automatically"],
          ["loop", "Repeats video"],
          ["muted", "Starts video muted"],
          ["poster", "Thumbnail image before play"],
          ["width/height", "Sets video dimensions"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Supported Video Formats"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Format", "Type"],
        "rows": [
          ["MP4", "video/mp4"],
          ["WebM", "video/webm"],
          ["OGG", "video/ogg"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Multiple Source Example"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<video controls width=\"400\">\n  <source src=\"video.mp4\" type=\"video/mp4\">\n  <source src=\"video.webm\" type=\"video/webm\">\n</video>"
    },
    {
      "type": "heading",
      "value": "Poster Attribute Example"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<video controls poster=\"thumbnail.jpg\" width=\"400\">\n  <source src=\"video.mp4\" type=\"video/mp4\">\n</video>"
    },
    {
      "type": "heading",
      "value": "Autoplay and Muted Example"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<video autoplay muted loop>\n  <source src=\"video.mp4\" type=\"video/mp4\">\n</video>"
    },
    {
      "type": "heading",
      "value": "Fallback Text"
    },
    {
      "type": "text",
      "value": "Fallback text is shown if the browser does not support the video tag."
    },
    {
      "type": "code",
      "language": "html",
      "value": "<video controls>\n  <source src=\"video.mp4\" type=\"video/mp4\">\n  Your browser does not support HTML video.\n</video>"
    },
