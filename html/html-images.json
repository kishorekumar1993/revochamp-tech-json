    },
    {
      "type": "text",
      "value": "Responsive images adjust based on screen size using CSS or HTML attributes."
    },
    {
      "type": "code",
      "language": "html",
      "value": "<img src=\"image.jpg\" style=\"max-width:100%; height:auto;\">"
    },
    {
      "type": "heading",
      "value": "Picture Element (Advanced)"
    },
    {
      "type": "text",
      "value": "The <picture> tag allows different images for different screen sizes."
    },
    {
      "type": "code",
      "language": "html",
      "value": "<picture>\n  <source media=\"(max-width:600px)\" srcset=\"small.jpg\">\n  <source media=\"(max-width:1200px)\" srcset=\"medium.jpg\">\n  <img src=\"large.jpg\" alt=\"Responsive Image\">\n</picture>"
    },
