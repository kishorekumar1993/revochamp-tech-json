    },
    {
      "type": "text",
      "value": "HTML images are used to display pictures on a webpage using the <img> tag. Images enhance user experience and make content visually appealing."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<img src=\"image.jpg\" alt=\"Description of image\">"
    },
    {
      "type": "heading",
      "value": "Important Attributes"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Attribute", "Purpose", "Example"],
        "rows": [
          ["src", "Image source path", "<img src=\"img.jpg\">"],
          ["alt", "Alternative text", "<img alt=\"image\">"],
          ["width", "Image width", "<img width=\"200\">"],
          ["height", "Image height", "<img height=\"100\">"],
          ["title", "Tooltip text", "<img title=\"Image\">"],
          ["loading", "Lazy loading", "<img loading=\"lazy\">"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Example Usage"
    },
    {
