          ["href", "Destination URL"],
          ["target", "Where to open link"],
          ["title", "Tooltip text"],
          ["rel", "Relationship (e.g., noopener)"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Best Practices"
    },
    {
      "type": "list",
      "value": [
