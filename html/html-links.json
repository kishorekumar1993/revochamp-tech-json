    {
      "type": "heading",
      "value": "What are HTML Links?"
    },
    {
      "type": "text",
      "value": "HTML links (hyperlinks) allow users to navigate between web pages, sections, or external resources using the anchor (<a>) tag."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<a href=\"https://example.com\">Visit Website</a>"
    },
    {
      "type": "heading",
      "value": "Common Link Types"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Type", "Example", "Description"],
        "rows": [
          ["External Link", "<a href=\"https://google.com\">Google</a>", "Navigates to another website"],
          ["Internal Link", "<a href=\"/about.html\">About</a>", "Navigates within the same site"],
          ["Anchor Link", "<a href=\"#section1\">Go to Section</a>", "Scrolls to a specific section"],
          ["Email Link", "<a href=\"mailto:test@example.com\">Send Email</a>", "Opens email client"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Opening Links in New Tab"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<a href=\"https://example.com\" target=\"_blank\">Open in New Tab</a>"
    },
    {
      "type": "heading",
      "value": "Linking to Page Sections"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<a href=\"#contact\">Go to Contact</a>\n\n<h2 id=\"contact\">Contact Section</h2>"
    },
    {
      "type": "heading",
      "value": "Using Images as Links"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<a href=\"https://example.com\">\n  <img src=\"image.jpg\" alt=\"Click here\">\n</a>"
    },
    {
      "type": "heading",
      "value": "Important Attributes"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Attribute", "Purpose"],
