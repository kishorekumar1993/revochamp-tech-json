    {
      "type": "heading",
      "value": "What is HTML Canvas?"
    },
    {
      "type": "text",
      "value": "The <canvas> element is used to draw graphics on a webpage using JavaScript. It can be used for animations, games, charts, and visual effects."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<canvas id=\"myCanvas\" width=\"300\" height=\"200\"></canvas>"
    },
    {
      "type": "heading",
      "value": "Accessing Canvas in JavaScript"
    },
    {
      "type": "code",
      "language": "javascript",
      "value": "const canvas = document.getElementById('myCanvas');\nconst ctx = canvas.getContext('2d');"
    },
    {
      "type": "heading",
      "value": "Drawing a Rectangle"
    },
    {
      "type": "code",
      "language": "javascript",
      "value": "ctx.fillStyle = 'blue';\nctx.fillRect(20, 20, 150, 100);"
    },
    {
      "type": "heading",
      "value": "Drawing a Line"
    },
    {
      "type": "code",
      "language": "javascript",
      "value": "ctx.beginPath();\nctx.moveTo(0, 0);\nctx.lineTo(200, 100);\nctx.stroke();"
    },
    {
      "type": "heading",
      "value": "Drawing a Circle"
    },
    {
      "type": "code",
      "language": "javascript",
      "value": "ctx.beginPath();\nctx.arc(100, 75, 50, 0, 2 * Math.PI);\nctx.stroke();"
    },
    {
      "type": "heading",
      "value": "Adding Text"
    },
    {
      "type": "code",
      "language": "javascript",
      "value": "ctx.font = '20px Arial';\nctx.fillText('Hello Canvas', 50, 50);"
    },
    {
      "type": "heading",
      "value": "Canvas vs SVG"
