    {
      "type": "heading",
      "value": "What are Width & Height?"
    },
    {
      "type": "text",
      "value": "Width and height properties define the size of an element's content area."
    },
    {
      "type": "heading",
      "value": "Basic Example"
    },
    {
      "type": "code",
      "language": "css",
      "value": "div {\n  width: 200px;\n  height: 100px;\n}"
    },
    {
      "type": "heading",
      "value": "Using Percentage"
    },
    {
      "type": "code",
      "language": "css",
      "value": "div {\n  width: 50%;\n  height: 50%;\n}"
    },
    {
      "type": "heading",
      "value": "Min and Max Properties"
    },
    {
      "type": "code",
      "language": "css",
      "value": "div {\n  min-width: 150px;\n  max-width: 500px;\n  min-height: 100px;\n  max-height: 300px;\n}"
    },
    {
      "type": "heading",
      "value": "Auto Value"
    },
    {
      "type": "code",
      "language": "css",
      "value": "div {\n  width: auto;\n  height: auto;\n}"
    },
    {
      "type": "heading",
      "value": "Responsive Units"
    },
    {
      "type": "code",
      "language": "css",
      "value": "div {\n  width: 50vw;\n  height: 30vh;\n}"
    },
    {
      "type": "heading",
      "value": "Width vs Max-Width"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Property", "Behavior"],
        "rows": [
          ["width", "Fixed or relative size"],
          ["max-width", "Limits maximum size (responsive)"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Example: Responsive Image"
    },
    {
      "type": "code",
      "language": "css",
      "value": "img {\n  max-width: 100%;\n  height: auto;\n}"
    },
    {
      "type": "heading",
      "value": "Box Model Impact"
    },
    {
      "type": "text",
      "value": "Width and height apply to content only by default. Padding and border add to the total size unless box-sizing is used."
    },
    {
      "type": "code",
      "language": "css",
      "value": "div {\n  box-sizing: border-box;\n}"
    },
    {
