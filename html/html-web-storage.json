  "faq": [
    {
      "question": "What is localStorage?",
      "answer": "It stores data permanently in the browser until manually removed."
    },
    {
      "question": "What is sessionStorage?",
      "answer": "It stores data temporarily until the browser tab is closed."
    },
    {
      "question": "Is Web Storage secure?",
      "answer": "It is safer than cookies but should not store sensitive data."
    }
