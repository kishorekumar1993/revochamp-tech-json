    },
    {
      "type": "text",
      "value": "HTML elements are categorized into block-level and inline elements based on how they behave in a layout."
    },
    {
      "type": "heading",
      "value": "Block-Level Elements"
    },
    {
      "type": "text",
      "value": "Block elements take up the full width available and start on a new line."
    },
    {
      "type": "code",
      "language": "html",
      "value": "<div>This is a block element</div>\n<p>This is a paragraph</p>"
    },
