  "content": [
    {
      "type": "heading",
      "value": "What is CSS Grid?"
    },
    {
      "type": "text",
      "value": "CSS Grid is a two-dimensional layout system that allows you to design layouts using rows and columns."
    },
    {
      "type": "heading",
      "value": "Grid Container"
    },
    {
      "type": "code",
      "language": "css",
      "value": ".container {\n  display: grid;\n}"
    },
    {
      "type": "heading",
      "value": "Grid Columns"
    },
    {
      "type": "code",
      "language": "css",
      "value": ".container {\n  grid-template-columns: 1fr 1fr 1fr;\n}"
    },
    {
      "type": "heading",
      "value": "Grid Rows"
    },
    {
      "type": "code",
      "language": "css",
      "value": ".container {\n  grid-template-rows: 100px 200px;\n}"
    },
    {
      "type": "heading",
      "value": "Gap (Spacing)"
    },
    {
      "type": "code",
      "language": "css",
      "value": ".container {\n  gap: 10px;\n}"
    },
    {
      "type": "heading",
      "value": "Grid Item Placement"
    },
    {
      "type": "code",
      "language": "css",
      "value": ".item {\n  grid-column: 1 / 3;\n  grid-row: 1 / 2;\n}"
    },
    {
      "type": "heading",
      "value": "Repeat Function"
    },
    {
      "type": "code",
      "language": "css",
      "value": ".container {\n  grid-template-columns: repeat(3, 1fr);\n}"
    },
    {
      "type": "heading",
      "value": "Auto-Fit & Minmax"
    },
    {
      "type": "code",
      "language": "css",
      "value": ".container {\n  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n}"
    },
    {
      "type": "heading",
      "value": "Alignment"
    },
    {
      "type": "code",
      "language": "css",
      "value": ".container {\n  justify-items: center;\n  align-items: center;\n}"
    },
    {
