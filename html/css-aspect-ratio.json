    },
    {
      "type": "text",
      "value": "The aspect-ratio property defines the proportional relationship between width and height of an element."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "css",
      "value": "div {\n  aspect-ratio: 16 / 9;\n}"
    },
    {
      "type": "heading",
      "value": "Example"
    },
    {
      "type": "code",
      "language": "css",
      "value": ".box {\n  width: 300px;\n  aspect-ratio: 1 / 1;\n  background: lightblue;\n}"
    },
    {
      "type": "heading",
      "value": "Responsive Usage"
    },
    {
      "type": "code",
      "language": "css",
      "value": "img {\n  width: 100%;\n  aspect-ratio: 16 / 9;\n  object-fit: cover;\n}"
