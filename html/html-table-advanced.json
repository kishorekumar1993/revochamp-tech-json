    {
      "type": "heading",
      "value": "Why Advanced Tables?"
    },
    {
      "type": "text",
      "value": "Advanced HTML tables improve usability, accessibility, and responsiveness. They are essential for handling large datasets and complex layouts."
    },
    {
      "type": "heading",
      "value": "Table Caption"
    },
    {
      "type": "text",
      "value": "The <caption> tag provides a title for the table."
    },
    {
      "type": "code",
      "language": "html",
      "value": "<table>\n  <caption>Student Data</caption>\n  <tr>\n    <th>Name</th>\n    <th>Age</th>\n  </tr>\n</table>"
    },
    {
      "type": "heading",
      "value": "Column Grouping (colgroup)"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<table>\n  <colgroup>\n    <col style=\"background-color: #f2f2f2\">\n    <col>\n  </colgroup>\n  <tr>\n    <th>Name</th>\n    <th>Age</th>\n  </tr>\n</table>"
    },
    {
      "type": "heading",
      "value": "Accessibility (scope & headers)"
    },
    {
      "type": "text",
      "value": "Use scope and headers attributes to improve accessibility for screen readers."
    },
    {
      "type": "code",
      "language": "html",
      "value": "<table>\n  <tr>\n    <th scope=\"col\">Name</th>\n    <th scope=\"col\">Age</th>\n  </tr>\n  <tr>\n    <td>John</td>\n    <td>25</td>\n  </tr>\n</table>"
    },
    {
      "type": "heading",
      "value": "Responsive Tables"
    },
    {
      "type": "text",
      "value": "Wrap tables in a container with overflow for better responsiveness."
    },
    {
      "type": "code",
      "language": "html",
      "value": "<div style=\"overflow-x:auto;\">\n  <table>\n    <tr>\n      <th>Name</th>\n      <th>Age</th>\n    </tr>\n  </table>\n</div>"
    },
    {
      "type": "heading",
      "value": "Striped Table Styling"
    },
    {
      "type": "code",
      "language": "css",
      "value": "tr:nth-child(even) {\n  background-color: #f2f2f2;\n}"
    },
    {
      "type": "heading",
      "value": "Hover Effect"
    },
    {
      "type": "code",
      "language": "css",
      "value": "tr:hover {\n  background-color: #ddd;\n}"
    },
    {
      "type": "heading",
      "value": "Sticky Header"
    },
    {
      "type": "code",
      "language": "css",
      "value": "th {\n  position: sticky;\n  top: 0;\n  background: white;\n}"
    },
    {
      "type": "heading",
      "value": "Scrollable Table"
    },
    {
      "type": "code",
      "language": "css",
      "value": ".table-container {\n  max-height: 300px;\n  overflow-y: auto;\n}"
    },
