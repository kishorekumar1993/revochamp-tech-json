  "faq": [
    {
      "question": "What is preload?",
      "answer": "It loads important resources early."
    },
    {
      "question": "What is prefetch?",
      "answer": "It loads resources for future use."
    },
    {
      "question": "What is preconnect?",
      "answer": "It establishes early connection to a server."
    }
  ],

