          ["WebM", "Better compression for web"],
          ["Ogg", "Open format with limited support"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Basic Example"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<video controls>\n  <source src=\"video.mp4\" type=\"video/mp4\">\n</video>"
    },
