      "type": "heading",
      "value": "What are Props?"
    },
    {
      "type": "text",
      "value": "Props are custom attributes used to pass data from a parent component to a child component in Vue."
    },
    {
      "type": "heading",
      "value": "Basic Example"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<child-component message=\"Hello\"></child-component>"
    },
    {
      "type": "code",
      "language": "javascript",
      "value": "export default {\n  props: ['message']\n}"
    },
    {
      "type": "heading",
      "value": "Dynamic Props"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<child-component :count=\"num\"></child-component>"
    },
    {
      "type": "heading",
      "value": "Props Validation"
    },
    {
      "type": "code",
      "language": "javascript",
      "value": "props: {\n  title: String,\n  age: Number\n}"
    },
    {
      "type": "heading",
      "value": "Default Values"
    },
    {
      "type": "code",
      "language": "javascript",
      "value": "props: {\n  name: {\n    type: String,\n    default: 'Guest'\n  }\n}"
    },
    {
      "type": "heading",
      "value": "Required Props"
    },
    {
      "type": "code",
      "language": "javascript",
      "value": "props: {\n  id: {\n    type: Number,\n    required: true\n  }\n}"
    },
