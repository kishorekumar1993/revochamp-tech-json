      "value": "What is Interpolation?"
    },
    {
      "type": "text",
      "value": "Interpolation in Vue is used to display dynamic data in the DOM using double curly braces {{ }}."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<p>{{ message }}</p>"
    },
    {
      "type": "heading",
      "value": "Using Expressions"
    },
    {
      "type": "text",
      "value": "You can use JavaScript expressions inside interpolation."
    },
    {
      "type": "code",
      "language": "html",
      "value": "<p>{{ 5 + 5 }}</p>\n<p>{{ message.toUpperCase() }}</p>"
    },
    {
      "type": "heading",
      "value": "Multiple Interpolations"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<p>{{ firstName }} {{ lastName }}</p>"
    },
    {
      "type": "heading",
      "value": "Raw HTML (v-html)"
    },
    {
      "type": "text",
      "value": "Use v-html directive to render raw HTML instead of plain text."
    },
    {
      "type": "code",
      "language": "html",
      "value": "<div v-html=\"rawHtml\"></div>"
    },
