  "content": [
    {
      "type": "heading",
      "value": "What is v-for?"
    },
    {
      "type": "text",
      "value": "The v-for directive is used to render a list of items by iterating over arrays or objects."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<li v-for=\"item in items\">{{ item }}</li>"
    },
    {
      "type": "heading",
      "value": "With Index"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<li v-for=\"(item, index) in items\">\n  {{ index }} - {{ item }}\n</li>"
    },
    {
      "type": "heading",
      "value": "Using Key"
    },
    {
      "type": "text",
      "value": "The key attribute helps Vue track elements efficiently."
    },
    {
      "type": "code",
      "language": "html",
      "value": "<li v-for=\"item in items\" :key=\"item.id\">\n  {{ item.name }}\n</li>"
    },
    {
      "type": "heading",
      "value": "Looping Through Objects"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<li v-for=\"(value, key) in user\">\n  {{ key }}: {{ value }}\n</li>"
    },
    {
      "type": "heading",
      "value": "Looping Numbers"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<p v-for=\"n in 5\">{{ n }}</p>"
    },
    {
      "type": "heading",
      "value": "Best Practices"
    },
