    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<img v-bind:src=\"imageUrl\">"
    },
    {
      "type": "heading",
      "value": "Shorthand Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<img :src=\"imageUrl\">"
    },
    {
      "type": "heading",
      "value": "Binding Classes"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<div :class=\"isActive ? 'active' : ''\"></div>"
    },
    {
      "type": "heading",
      "value": "Binding Styles"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<div :style=\"{ color: textColor, fontSize: size + 'px' }\"></div>"
