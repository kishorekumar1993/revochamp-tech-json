  "faq": [
    {
      "question": "What is v-model?",
      "answer": "It provides two-way data binding between input and data."
    },
    {
      "question": "What is v-bind?",
      "answer": "It binds HTML attributes dynamically."
    },
    {
      "question": "What is one-way binding?",
      "answer": "Data flows from model to view only."
    }
