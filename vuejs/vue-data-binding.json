  "content": [
    {
      "type": "heading",
      "value": "What is Data Binding?"
    },
    {
      "type": "text",
      "value": "Data binding in Vue connects the data model with the UI, ensuring that changes in data automatically update the view."
    },
    {
      "type": "heading",
      "value": "One-Way Data Binding"
    },
    {
      "type": "text",
      "value": "Data flows from the model to the view. When data changes, the UI updates automatically."
    },
    {
      "type": "code",
      "language": "html",
      "value": "<p>{{ message }}</p>\n<img :src=\"imageUrl\">"
    },
    {
      "type": "heading",
      "value": "v-bind Directive"
    },
    {
      "type": "text",
      "value": "The v-bind directive dynamically binds HTML attributes to data."
    },
    {
      "type": "code",
      "language": "html",
      "value": "<a v-bind:href=\"url\">Visit</a>\n<!-- Shorthand -->\n<a :href=\"url\">Visit</a>"
    },
    {
      "type": "heading",
      "value": "Two-Way Data Binding"
    },
    {
      "type": "text",
      "value": "Two-way binding allows data to flow between the model and the view, updating both automatically."
    },
    {
      "type": "heading",
      "value": "v-model Directive"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<input v-model=\"name\">\n<p>{{ name }}</p>"
    },
    {
      "type": "heading",
      "value": "Binding Types"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Type", "Directive", "Description"],
        "rows": [
          ["Text", "{{ }}", "Display data"],
          ["Attribute", "v-bind", "Bind attributes"],
          ["Two-way", "v-model", "Sync input and data"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Event Binding (Related)"
    },
