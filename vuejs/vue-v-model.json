  "content": [
    {
      "type": "heading",
      "value": "What is v-model?"
    },
    {
      "type": "text",
      "value": "The v-model directive creates two-way data binding between form inputs and Vue data."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<input v-model=\"name\">\n<p>{{ name }}</p>"
    },
    {
      "type": "heading",
      "value": "Text Input Example"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<input v-model=\"message\" placeholder=\"Enter text\">\n<p>{{ message }}</p>"
    },
    {
      "type": "heading",
      "value": "Checkbox Binding"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<input type=\"checkbox\" v-model=\"isChecked\">\n<p>{{ isChecked }}</p>"
    },
    {
      "type": "heading",
      "value": "Radio Button Binding"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<input type=\"radio\" value=\"Male\" v-model=\"gender\">\n<input type=\"radio\" value=\"Female\" v-model=\"gender\">\n<p>{{ gender }}</p>"
    },
    {
      "type": "heading",
      "value": "Select Dropdown"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<select v-model=\"selected\">\n  <option>Option 1</option>\n  <option>Option 2</option>\n</select>\n<p>{{ selected }}</p>"
    },
    {
      "type": "heading",
      "value": "Modifiers"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Modifier", "Description"],
        "rows": [
          [".lazy", "Updates on change event instead of input"],
          [".number", "Converts input to number"],
          [".trim", "Trims whitespace"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Modifiers Example"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<input v-model.lazy=\"name\">\n<input v-model.number=\"age\">\n<input v-model.trim=\"text\">"
    },
