  "content": [
    {
      "type": "heading",
      "value": "What are Slots?"
    },
    {
      "type": "text",
      "value": "Slots allow you to pass content from a parent component into a child component, enabling flexible and reusable component layouts."
    },
    {
      "type": "heading",
      "value": "Default Slot"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<!-- Child -->\n<div>\n  <slot></slot>\n</div>\n\n<!-- Parent -->\n<my-component>\n  <p>Hello Slot</p>\n</my-component>"
    },
    {
      "type": "heading",
      "value": "Named Slots"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<!-- Child -->\n<header><slot name=\"header\"></slot></header>\n<main><slot></slot></main>\n\n<!-- Parent -->\n<my-component>\n  <template v-slot:header>\n    <h1>Title</h1>\n  </template>\n  <p>Content</p>\n</my-component>"
    },
    {
      "type": "heading",
      "value": "Scoped Slots"
    },
    {
      "type": "text",
      "value": "Scoped slots allow child components to pass data to slot content."
    },
    {
      "type": "code",
      "language": "html",
      "value": "<!-- Child -->\n<slot :user=\"user\"></slot>\n\n<!-- Parent -->\n<my-component v-slot=\"slotProps\">\n  {{ slotProps.user.name }}\n</my-component>"
    },
    {
      "type": "heading",
      "value": "Shorthand Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<template #header>\n  <h1>Header</h1>\n</template>"
    },
    {
      "type": "heading",
      "value": "Fallback Content"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<slot>Default Content</slot>"
    },
    {
