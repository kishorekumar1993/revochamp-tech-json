    },
    {
      "type": "text",
      "value": "The v-if directive is used to conditionally render elements in the DOM based on a boolean expression."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<p v-if=\"isVisible\">Hello Vue</p>"
    },
    {
      "type": "heading",
      "value": "v-else and v-else-if"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<p v-if=\"score > 80\">Excellent</p>\n<p v-else-if=\"score > 50\">Good</p>\n<p v-else>Try Again</p>"
    },
