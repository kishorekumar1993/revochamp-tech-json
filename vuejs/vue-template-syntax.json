  "content": [
    {
      "type": "heading",
      "value": "What is Template Syntax?"
    },
    {
      "type": "text",
      "value": "Vue template syntax allows you to bind data to the DOM using HTML-based templates with special directives and expressions."
    },
    {
      "type": "heading",
      "value": "Text Interpolation"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<p>{{ message }}</p>"
    },
    {
      "type": "text",
      "value": "Double curly braces {{ }} are used to display dynamic data."
    },
    {
      "type": "heading",
      "value": "Directives"
    },
    {
      "type": "text",
      "value": "Directives are special attributes prefixed with v- that apply reactive behavior to the DOM."
    },
    {
      "type": "code",
      "language": "html",
      "value": "<p v-if=\"isVisible\">Hello Vue</p>"
    },
    {
      "type": "heading",
      "value": "Common Directives"
    },
    {
      "type": "table",
      "value": {
        "headers": ["Directive", "Usage"],
        "rows": [
          ["v-if", "Conditional rendering"],
          ["v-for", "Loop through data"],
          ["v-bind", "Bind attributes"],
          ["v-on", "Handle events"],
          ["v-model", "Two-way binding"]
        ]
      }
    },
    {
      "type": "heading",
      "value": "Attribute Binding"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<img v-bind:src=\"imageUrl\">"
    },
    {
      "type": "heading",
      "value": "Shorthand Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<img :src=\"imageUrl\">\n<button @click=\"handleClick\">Click</button>"
    },
    {
      "type": "heading",
      "value": "JavaScript Expressions"
    },
    {
      "type": "code",
      "language": "html",
      "value": "{{ message.toUpperCase() }}"
    },
