  "content": [
    {
      "type": "heading",
      "value": "What are Dynamic Components?"
    },
    {
      "type": "text",
      "value": "Dynamic components allow you to switch between different components dynamically using the <component> element."
    },
    {
      "type": "heading",
      "value": "Basic Syntax"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<component :is=\"currentComponent\"></component>"
    },
    {
      "type": "heading",
      "value": "Example"
    },
    {
      "type": "code",
      "language": "html",
      "value": "<button @click=\"current = 'CompA'\">A</button>\n<button @click=\"current = 'CompB'\">B</button>\n\n<component :is=\"current\"></component>"
    },
    {
      "type": "heading",
      "value": "Registering Components"
    },
    {
      "type": "code",
      "language": "javascript",
      "value": "components: {\n  CompA,\n  CompB\n}"
    },
    {
      "type": "heading",
      "value": "Keep Alive"
    },
    {
      "type": "text",
      "value": "Use <keep-alive> to cache inactive components and preserve state."
    },
    {
      "type": "code",
      "language": "html",
      "value": "<keep-alive>\n  <component :is=\"currentComponent\"></component>\n</keep-alive>"
    },
    {
