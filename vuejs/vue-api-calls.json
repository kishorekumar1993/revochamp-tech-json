    },
    {
      "type": "code",
      "language": "javascript",
      "value": "import axios from 'axios';\n\naxios.get('https://api.example.com/data')\n  .then(response => console.log(response.data));"
    },
    {
      "type": "heading",
      "value": "Async/Await Example"
    },
    {
      "type": "code",
      "language": "javascript",
      "value": "async mounted() {\n  const res = await fetch('https://api.example.com/data');\n  const data = await res.json();\n  console.log(data);\n}"
